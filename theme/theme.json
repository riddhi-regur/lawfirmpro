{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "useRootPaddingAwareAlignments": true,

    "layout": {
      "contentSize": "1200px",
      "wideSize": "1400px"
    },

    "spacing": {
      "units": ["px", "em", "rem", "%", "vh", "vw"],
      "spacingSizes": [
        {
          "slug": "xs",
          "size": "8px",
          "name": "XS"
        },
        {
          "slug": "sm",
          "size": "16px",
          "name": "SM"
        },
        {
          "slug": "md",
          "size": "24px",
          "name": "MD"
        },
        {
          "slug": "lg",
          "size": "40px",
          "name": "LG"
        },
        {
          "slug": "xl",
          "size": "64px",
          "name": "XL"
        }
      ]
    },

    "color": {
      "defaultPalette": false,
      "palette": [
        {
          "slug": "primary",
          "name": "Black",
          "color": "#000000"
        },
        {
          "slug": "secondary",
          "name": "White",
          "color": "#FFFFFF"
        },
        {
          "slug": "accent",
          "name": "Dark Gray",
          "color": "#334155"
        },
        {
          "slug": "background",
          "name": "White",
          "color": "#FFFFFF"
        }
      ]
    },

    "typography": {
      "fluid": true,
      "fontFamilies": [
        {
          "fontFamily": "\"Playfair Display\", serif",
          "slug": "heading",
          "name": "Playfair Display"
        },
        {
          "fontFamily": "Inter, sans-serif",
          "slug": "body",
          "name": "Inter"
        }
      ],

      "fontSizes": [
        {
          "slug": "small",
          "size": "14px",
          "name": "Small"
        },
        {
          "slug": "medium",
          "size": "18px",
          "name": "Medium"
        },
        {
          "slug": "large",
          "size": "32px",
          "name": "Large"
        },
        {
          "slug": "x-large",
          "size": "56px",
          "name": "Extra Large"
        }
      ]
    },

    "border": {
      "radius": true
    }
  },

  "styles": {
    "color": {
      "background": "#FFFFFF",
      "text": "#000000"
    },

    "typography": {
      "fontFamily": "var(--wp--preset--font-family--body)",
      "lineHeight": "1.7"
    },

    "elements": {
      "heading": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--heading)"
        }
      },

      "button": {
        "color": {
          "background": "#000000",
          "text": "#FFFFFF"
        },
        "border": {
          "radius": "0px"
        },
        "spacing": {
          "padding": {
            "top": "14px",
            "bottom": "14px",
            "left": "24px",
            "right": "24px"
          }
        }
      }
    }
  }
}